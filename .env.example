# ============================================================
# Bot Uzed — variables de entorno (global, multi-tenant)
# ============================================================
# Este bot es multi-tenant: no tiene vars por organización.
# Las clínicas conectan sus números de WhatsApp vía la tabla
# public.organization_whatsapp_channels (lookup por phone_number_id).
# ============================================================

# ── WhatsApp Cloud API (modo "managed", credenciales globales) ──
# Todas las orgs que conecten en modo managed usan este token.
# En modo self_service (futuro), el token viene de la tabla de canales.
WHATSAPP_ACCESS_TOKEN=EAA...
WHATSAPP_APP_SECRET=...
WHATSAPP_VERIFY_TOKEN=uzed-bot-verify-2026
# Nota: WHATSAPP_PHONE_NUMBER_ID ya no se usa como global — ahora se
# extrae del payload del webhook (value.metadata.phone_number_id).

# ── Supabase ──
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Anon key — usada solo para validar JWTs del panel Angular en /staff/*
SUPABASE_ANON_KEY=eyJ...

# ── Server ──
PORT=3000
LOG_LEVEL=info

# ── LLM Provider ─────────────────────────────────────────────
# "google" (GRATIS) o "anthropic" (de pago)
LLM_PROVIDER=google

# Google Gemini (gratuito, tier 15 req/min / 1500 req/dia)
# Generar en https://aistudio.google.com/apikey
GOOGLE_API_KEY=ai...

# Anthropic Claude (de pago, cuando quieras migrar)
# Requiere créditos en console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS para el panel Angular ────────────────────────────────
# Orígenes permitidos para las rutas /staff/*. Coma-separado.
# Ej: https://app.uzedsolutions.com,http://localhost:4200
CORS_ALLOWED_ORIGINS=https://app.uzedsolutions.com,http://localhost:4200

# ── Bot scripted: WhatsApp Flow opt-in para registro de paciente ──
# El bot scripted (mode='scripted' en org_settings.whatsapp_bot_mode)
# puede pedir los datos del paciente de dos formas:
#   1) Secuencialmente por mensajes (default, no requiere nada).
#   2) Con un mini-form nativo de WhatsApp (Flow estático).
#
# Para habilitar (2), publicar docs/flows/registro_paciente.json en
# WhatsApp Manager (ver docs/flows/README.md) y setear AMBAS variables:

# Si alguna de las dos falta / es false, el bot usa el flujo secuencial.
